---
// SPDX-FileCopyrightText: Copyright (C) Nicolas Lamirault <nicolas.lamirault@gmail.com>
// SPDX-License-Identifier: Apache-2.0

import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

const projects = [
  {
    n: "01",
    accent: "k8s",
    color: "#00e5b0",
    label: "Kubernetes Platform",
    repo: "portefaix-kubernetes",
    url: "https://github.com/portefaix/portefaix-kubernetes",
    description:
      "Production-grade Kubernetes configurations with GitOps workflows, operators, and everything needed to run clusters reliably at any scale.",
    tags: ["gitops", "operators", "observability", "argocd"],
    icon: `<svg viewBox="0 0 26 26" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="13,2 23,8 23,18 13,24 3,18 3,8"/>
      <circle cx="13" cy="13" r="2.8"/>
      <line x1="13" y1="2"   x2="13" y2="10.2"/>
      <line x1="23" y1="8"   x2="15.6" y2="11.7"/>
      <line x1="23" y1="18"  x2="15.6" y2="14.3"/>
      <line x1="13" y1="24"  x2="13" y2="15.8"/>
      <line x1="3"  y1="18"  x2="10.4" y2="14.3"/>
      <line x1="3"  y1="8"   x2="10.4" y2="11.7"/>
    </svg>`,
  },
  {
    n: "02",
    accent: "tf",
    color: "#a78bfa",
    label: "GitOps Delivery",
    repo: "portefaix-kubernetes",
    url: "https://github.com/portefaix/portefaix-kubernetes",
    description:
      "Declarative, Git-driven delivery with ArgoCD and Flux. Every cluster state is version-controlled, auditable, and automatically reconciled — no manual kubectl in production.",
    tags: ["argocd", "fluxcd", "gitops", "reconciliation"],
    icon: `<svg viewBox="0 0 26 26" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="5" cy="6" r="2.5"/>
      <circle cx="21" cy="6" r="2.5"/>
      <circle cx="5" cy="20" r="2.5"/>
      <path d="M7.5 6 L18.5 6"/>
      <path d="M5 8.5 L5 17.5"/>
      <path d="M18.5 6 Q24 6 24 12 Q24 20 21 20 Q18 20 13 20 L7.5 20"/>
      <polyline points="10,17 7.5,20 10,23"/>
    </svg>`,
  },
  {
    n: "03",
    accent: "hub",
    color: "#fb7185",
    label: "Helm Chart Hub",
    repo: "portefaix-hub",
    url: "https://github.com/portefaix/portefaix-hub",
    description:
      "Curated registry of Helm charts optimised for the Portefaix platform. Deploy applications consistently and repeatably across any target environment.",
    tags: ["helm", "charts", "oci", "registry"],
    icon: `<svg viewBox="0 0 26 26" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
      <circle cx="13" cy="13" r="11"/>
      <circle cx="13" cy="13" r="3"/>
      <line x1="13" y1="2"    x2="13" y2="10"/>
      <line x1="13" y1="16"   x2="13" y2="24"/>
      <line x1="2"  y1="13"   x2="10" y2="13"/>
      <line x1="16" y1="13"   x2="24" y2="13"/>
      <line x1="4.8" y1="4.8" x2="10.9" y2="10.9"/>
      <line x1="15.1" y1="15.1" x2="21.2" y2="21.2"/>
      <line x1="21.2" y1="4.8"  x2="15.1" y2="10.9"/>
      <line x1="10.9" y1="15.1" x2="4.8"  y2="21.2"/>
    </svg>`,
  },
  {
    n: "04",
    accent: "pol",
    color: "#fbbf24",
    label: "Platform Policies",
    repo: "portefaix-policies",
    url: "https://github.com/portefaix/portefaix-policies",
    description:
      "Kubernetes Validating Admission Policy (VAP) + CEL policy library enforcing security, compliance, and governance standards across your entire platform — from admission to runtime.",
    tags: ["vap", "cel", "security", "compliance"],
    icon: `<svg viewBox="0 0 26 26" fill="none" stroke="currentColor" stroke-width="1.3" stroke-linecap="round" stroke-linejoin="round">
      <path d="M13 2 L24 6.8 L24 15 C24 21.4 19.1 27 13 29 C6.9 27 2 21.4 2 15 L2 6.8 Z"/>
      <polyline points="8.5,14 12,17.5 17.5,11"/>
    </svg>`,
  },
];
---

<Layout title="Portefaix — Platform Engineering, Systematized">

  <!-- ═══════════════════════════════ NAV ═══ -->
  <nav
    style="position:fixed;inset-block-start:0;inset-inline:0;z-index:50;height:54px;display:flex;align-items:center;padding:0 clamp(20px,5vw,64px);background:rgba(10,11,14,0.82);border-bottom:1px solid rgba(0,229,176,0.08);backdrop-filter:blur(12px);-webkit-backdrop-filter:blur(12px);"
  >
    <div style="display:flex;align-items:center;justify-content:space-between;width:100%;max-width:1200px;margin:0 auto;">

      <a href="/" style="display:flex;align-items:center;gap:10px;text-decoration:none;" aria-label="Portefaix">
        <svg style="width:20px;height:20px;color:#00e5b0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <polygon points="12,2 21,7 21,17 12,22 3,17 3,7"/>
          <circle cx="12" cy="12" r="2" fill="currentColor" stroke="none"/>
        </svg>
        <span style="font-family:var(--font-d);font-size:0.95rem;font-weight:600;letter-spacing:0.1em;color:var(--t1);text-transform:uppercase;">
          Portefaix
        </span>
      </a>

      <div style="display:flex;align-items:center;gap:28px;">
        <a href="/docs/"
           style="font-family:var(--font-m);font-size:0.67rem;letter-spacing:0.1em;color:var(--t2);transition:color 0.2s;"
           onmouseover="this.style.color='var(--t1)'" onmouseout="this.style.color='var(--t2)'">
          DOCS
        </a>
        <a href="#ecosystem"
           style="font-family:var(--font-m);font-size:0.67rem;letter-spacing:0.1em;color:var(--t2);transition:color 0.2s;"
           onmouseover="this.style.color='var(--t1)'" onmouseout="this.style.color='var(--t2)'">
          ECOSYSTEM
        </a>
        <a
          href="https://github.com/portefaix"
          target="_blank"
          rel="noopener noreferrer"
          style="display:flex;align-items:center;gap:7px;font-family:var(--font-m);font-size:0.67rem;letter-spacing:0.1em;color:#00e5b0;border:1px solid rgba(0,229,176,0.25);padding:6px 14px;transition:background 0.2s,border-color 0.2s;"
          onmouseover="this.style.background='rgba(0,229,176,0.08)';this.style.borderColor='rgba(0,229,176,0.5)'"
          onmouseout="this.style.background='transparent';this.style.borderColor='rgba(0,229,176,0.25)'"
        >
          <svg style="width:13px;height:13px;" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          GITHUB
        </a>
      </div>

    </div>
  </nav>

  <!-- ═══════════════════════════════ HERO ══ -->
  <section class="scanline-hero" style="position:relative;z-index:10;min-height:100svh;display:flex;flex-direction:column;justify-content:center;padding:clamp(80px,12vw,140px) clamp(20px,5vw,64px) clamp(40px,8vw,80px);">

    <!-- Background corner accents -->
    <div aria-hidden="true" style="position:absolute;top:54px;right:0;width:clamp(200px,30vw,380px);height:1px;background:linear-gradient(to left,transparent,rgba(0,229,176,0.3));pointer-events:none;"></div>
    <div aria-hidden="true" style="position:absolute;top:54px;right:0;width:1px;height:clamp(80px,12vw,160px);background:linear-gradient(to bottom,rgba(0,229,176,0.3),transparent);pointer-events:none;"></div>
    <div aria-hidden="true" style="position:absolute;bottom:0;left:0;width:clamp(200px,30vw,380px);height:1px;background:linear-gradient(to right,transparent,rgba(0,229,176,0.12));pointer-events:none;"></div>

    <div style="max-width:1200px;margin:0 auto;width:100%;">

      <!-- System label -->
      <div class="e1" style="display:flex;align-items:center;gap:12px;font-family:var(--font-m);font-size:0.62rem;letter-spacing:0.16em;color:#00e5b0;margin-bottom:clamp(20px,4vw,36px);">
        <span class="sdot sdot--pulse" style="background:#00e5b0;color:#00e5b0;"></span>
        <span>SYSTEM STATUS: ONLINE</span>
        <span style="color:var(--t3);">—</span>
        <span style="color:var(--t3);">OPEN SOURCE PLATFORM TOOLKIT</span>
      </div>

      <!-- Main heading -->
      <h1
        class="e2"
        style="font-family:var(--font-d);font-weight:700;line-height:0.92;letter-spacing:-0.01em;text-transform:uppercase;color:var(--t1);margin-bottom:clamp(20px,4vw,36px);font-size:clamp(3.8rem,11vw,9.5rem);"
      >
        Platform<br />
        <span style="color:#00e5b0;">Engineering</span><span style="color:var(--t3);">,</span><br />
        Systematized.
      </h1>

      <!-- Rule -->
      <div class="e3" style="width:clamp(60px,8vw,100px);height:2px;background:#00e5b0;margin-bottom:clamp(18px,3vw,28px);"></div>

      <!-- Description -->
      <p class="e3" style="font-family:var(--font-b);font-weight:300;font-size:clamp(1rem,1.8vw,1.15rem);color:var(--t2);max-width:520px;line-height:1.75;margin-bottom:clamp(28px,5vw,44px);">
        A complete toolkit for building production-grade Kubernetes platforms
        on any cloud — GitOps-driven, policy-enforced, built to scale.
      </p>

      <!-- CTAs -->
      <div class="e4" style="display:flex;flex-wrap:wrap;gap:14px;margin-bottom:clamp(32px,6vw,56px);">
        <a
          href="#ecosystem"
          style="display:inline-flex;align-items:center;gap:10px;font-family:var(--font-m);font-size:0.75rem;letter-spacing:0.1em;color:#00e5b0;border:1px solid #00e5b0;padding:13px 26px;transition:background 0.2s,box-shadow 0.2s;text-transform:uppercase;"
          onmouseover="this.style.background='rgba(0,229,176,0.1)';this.style.boxShadow='0 0 20px rgba(0,229,176,0.15)'"
          onmouseout="this.style.background='transparent';this.style.boxShadow='none'"
        >
          Explore Ecosystem
          <svg style="width:15px;height:15px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a
          href="/docs/"
          style="display:inline-flex;align-items:center;gap:10px;font-family:var(--font-m);font-size:0.75rem;letter-spacing:0.1em;color:var(--t2);border:1px solid rgba(232,240,237,0.14);padding:13px 26px;transition:color 0.2s,border-color 0.2s;text-transform:uppercase;"
          onmouseover="this.style.color='var(--t1)';this.style.borderColor='rgba(232,240,237,0.35)'"
          onmouseout="this.style.color='var(--t2)';this.style.borderColor='rgba(232,240,237,0.14)'"
        >
          Documentation
          <svg style="width:13px;height:13px;opacity:0.6;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M7 17L17 7M17 7H7M17 7v10"/>
          </svg>
        </a>
      </div>

      <!-- Tag rail -->
      <div class="e5" style="display:flex;flex-wrap:wrap;gap:8px;">
        {["kubernetes", "terraform", "helm", "gitops", "opa", "argocd", "fluxcd", "open-source"].map((t) => (
          <span class="ntag">{t}</span>
        ))}
      </div>

    </div>

    <!-- Scroll indicator -->
    <div style="position:absolute;bottom:clamp(20px,4vw,36px);left:clamp(20px,5vw,64px);display:flex;align-items:center;gap:10px;opacity:0.3;">
      <div style="width:1px;height:40px;background:linear-gradient(to bottom,transparent,#00e5b0);"></div>
      <span style="font-family:var(--font-m);font-size:0.58rem;letter-spacing:0.14em;color:var(--t3);text-transform:uppercase;">Scroll</span>
    </div>

  </section>

  <!-- ══════════════════ CLOUD INFRASTRUCTURE ══ -->
  <section style="position:relative;z-index:10;padding:clamp(64px,10vw,120px) clamp(20px,5vw,64px) clamp(48px,8vw,80px);">
    <div style="max-width:1200px;margin:0 auto;">

      <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:clamp(32px,5vw,52px);flex-wrap:wrap;border-bottom:1px solid rgba(0,229,176,0.12);padding-bottom:28px;">
        <div>
          <p style="font-family:var(--font-m);font-size:0.58rem;letter-spacing:0.18em;color:#00e5b0;margin-bottom:10px;text-transform:uppercase;">
            01 // Cloud Infrastructure
          </p>
          <h2 style="font-family:var(--font-d);font-weight:700;font-size:clamp(1.8rem,4vw,3rem);color:var(--t1);letter-spacing:-0.01em;text-transform:uppercase;line-height:1.05;">
            Any Cloud, Same Platform
          </h2>
        </div>
        <p style="font-family:var(--font-b);font-weight:300;font-size:0.95rem;color:var(--t2);max-width:360px;line-height:1.65;">
          Consistent Kubernetes platform foundations across GCP, AWS, Azure, and Scaleway — same GitOps and observability patterns on every cloud.
        </p>
      </div>

      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,520px),1fr));gap:2px;">
        {[
          { cloud: "GCP", color: "#4285F4", label: "Google Cloud Platform", tags: ["GKE", "Shared VPC", "Workload Identity", "LGTM"], href: "/docs/guides/gcp/", note: "Multi-env · Private GKE · Cloud Armor" },
          { cloud: "AWS", color: "#FF9900", label: "Amazon Web Services",    tags: ["EKS", "Karpenter", "Pod Identity", "WAF"],   href: "/docs/guides/aws/",  note: "Multi-account · EKS · GuardDuty" },
          { cloud: "Azure", color: "#0089D6", label: "Microsoft Azure",      tags: ["AKS", "Cilium", "Hub-and-Spoke", "AGFC"],   href: "/docs/guides/azure/", note: "Hub-and-Spoke VNet · AKS · Firewall" },
          { cloud: "SCW", color: "#4F0599", label: "Scaleway",               tags: ["Kapsule", "Cilium", "Cockpit", "ESO"],       href: "/docs/guides/scaleway/", note: "Kapsule · Private VPC · Spacelift" },
        ].map((c) => (
          <a
            href={c.href}
            class="crev"
            style="display:block;text-decoration:none;border:1px solid rgba(255,255,255,0.06);transition:border-color 0.2s;padding:0;"
            onmouseover={`this.style.borderColor='${c.color}44'`}
            onmouseout="this.style.borderColor='rgba(255,255,255,0.06)'"
          >
            <!-- Card header -->
            <div style={`padding:0.4rem 0.9rem;background:${c.color}0d;border-bottom:1px solid ${c.color}22;display:flex;align-items:center;justify-content:space-between;`}>
              <span style={`font-family:var(--font-m);font-size:0.6rem;letter-spacing:0.1em;color:${c.color};opacity:0.85;`}>{c.note}</span>
              <span style="font-family:var(--font-m);font-size:0.58rem;letter-spacing:0.08em;color:var(--t3);opacity:0.6;">Learn more ↗</span>
            </div>
            <!-- Card body -->
            <div style="padding:clamp(14px,2vw,20px) clamp(16px,2.5vw,24px);display:flex;align-items:center;justify-content:space-between;gap:12px;">
              <div style="display:flex;align-items:center;gap:12px;">
                <span style={`font-family:var(--font-d);font-size:0.75rem;font-weight:700;color:${c.color};letter-spacing:0.08em;`}>{c.cloud}</span>
                <span style="font-family:var(--font-b);font-size:0.88rem;color:var(--t2);">{c.label}</span>
              </div>
              <div style="display:flex;flex-wrap:wrap;gap:5px;justify-content:flex-end;">
                {c.tags.map((t) => (
                  <span style={`font-family:var(--font-m);font-size:0.55rem;letter-spacing:0.08em;color:${c.color};border:1px solid ${c.color}28;padding:2px 7px;opacity:0.7;`}>{t}</span>
                ))}
              </div>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ══════════════════════ KUBERNETES PLATFORM ════ -->
  <section id="ecosystem" style="position:relative;z-index:10;padding:0 clamp(20px,5vw,64px) clamp(48px,8vw,80px);">
    <div style="max-width:1200px;margin:0 auto;">

      <!-- Section header -->
      <div style="display:flex;align-items:flex-end;justify-content:space-between;gap:20px;margin-bottom:clamp(40px,7vw,72px);flex-wrap:wrap;border-bottom:1px solid rgba(0,229,176,0.12);padding-bottom:28px;">
        <div>
          <p style="font-family:var(--font-m);font-size:0.58rem;letter-spacing:0.18em;color:#00e5b0;margin-bottom:10px;text-transform:uppercase;">
            02 // Kubernetes Platform
          </p>
          <h2 style="font-family:var(--font-d);font-weight:700;font-size:clamp(1.8rem,4vw,3rem);color:var(--t1);letter-spacing:-0.01em;text-transform:uppercase;line-height:1.05;">
            The Platform Stack
          </h2>
        </div>
        <p style="font-family:var(--font-b);font-weight:300;font-size:0.95rem;color:var(--t2);max-width:360px;line-height:1.65;">
          Four interconnected modules that form a complete, production-ready platform engineering toolkit.
        </p>
      </div>

      <!-- 2×2 card grid -->
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(min(100%,480px),1fr));gap:2px;">
        {projects.map((p) => (
          <a
            href={p.url}
            target="_blank"
            rel="noopener noreferrer"
            class={`crev wired wire-${p.accent} group`}
            aria-label={`${p.label} on GitHub`}
            style="display:block;text-decoration:none;padding:clamp(24px,3.5vw,40px);"
          >
            <!-- Top row: number + icon -->
            <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:20px;">
              <span style={`font-family:var(--font-d);font-size:2.8rem;font-weight:700;color:${p.color};opacity:0.12;line-height:1;`}>
                {p.n}
              </span>
              <div
                style={`width:38px;height:38px;display:flex;align-items:center;justify-content:center;border:1px solid ${p.color}28;color:${p.color};`}
                set:html={p.icon}
              />
            </div>

            <!-- Title -->
            <h3 style={`font-family:var(--font-d);font-weight:600;font-size:clamp(1.1rem,2vw,1.4rem);color:${p.color};text-transform:uppercase;letter-spacing:0.04em;margin-bottom:6px;`}>
              {p.label}
            </h3>
            <p style="font-family:var(--font-m);font-size:0.58rem;letter-spacing:0.08em;color:var(--t3);margin-bottom:16px;">
              {p.repo}
            </p>

            <!-- Description -->
            <p style="font-family:var(--font-b);font-weight:300;font-size:0.92rem;color:var(--t2);line-height:1.7;margin-bottom:22px;">
              {p.description}
            </p>

            <!-- Bottom row: tags + arrow -->
            <div style="display:flex;align-items:center;justify-content:space-between;gap:12px;">
              <div style="display:flex;flex-wrap:wrap;gap:6px;">
                {p.tags.map((t) => (
                  <span
                    class="ntag"
                    style={`border-color:${p.color}28;color:${p.color};opacity:0.6;`}
                  >
                    {t}
                  </span>
                ))}
              </div>
              <span class="carrow" style={`font-family:var(--font-m);font-size:0.9rem;color:${p.color};`}>→</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>

  <!-- ═══════════════════════ DOCS PANEL ══ -->
  <section style="position:relative;z-index:10;padding:0 clamp(20px,5vw,64px) clamp(64px,10vw,100px);">
    <div style="max-width:1200px;margin:0 auto;">

      <div
        style="border:1px solid rgba(0,229,176,0.14);border-left:3px solid #00e5b0;display:grid;grid-template-columns:1fr auto;gap:clamp(24px,4vw,56px);padding:clamp(28px,4vw,48px);align-items:center;"
        class="docs-cta-row"
      >
        <div>
          <p style="font-family:var(--font-m);font-size:0.58rem;letter-spacing:0.18em;color:#00e5b0;margin-bottom:10px;text-transform:uppercase;">
            03 // Documentation
          </p>
          <h2 style="font-family:var(--font-d);font-weight:700;font-size:clamp(1.5rem,3vw,2.2rem);color:var(--t1);text-transform:uppercase;letter-spacing:0.02em;margin-bottom:12px;">
            Learn the Platform
          </h2>
          <p style="font-family:var(--font-b);font-weight:300;font-size:0.95rem;color:var(--t2);max-width:520px;line-height:1.7;">
            Guides for GitOps workflows, ArgoCD bootstrapping, infrastructure on GCP / AWS / Azure / Scaleway — plus full component and policy references.
          </p>
        </div>

        <div style="display:flex;flex-direction:column;gap:8px;min-width:220px;">
          {[
            ["Getting Started", "/docs/"],
            ["GitOps Principles", "/docs/guides/gitops/"],
            ["Components", "/docs/reference/components/"],
            ["Policies", "/docs/reference/policies/"],
