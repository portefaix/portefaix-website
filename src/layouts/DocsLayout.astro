// SPDX-License-Identifier: Apache-2.0

import Layout from "./Layout.astro";
import "../styles/global.css";

export interface Props {
  title: string;
  description?: string;
  section?: string;
}

const { title, description, section = "" } = Astro.props;

const nav = [
  {
    label: "Getting Started",
    items: [
      { label: "Overview", href: "/docs/" },
      { label: "Community", href: "/docs/community/" },
    ],
  },
  {
    label: "Guides",
    items: [
      { label: "GitOps Principles", href: "/docs/guides/gitops/" },
      { label: "ArgoCD", href: "/docs/guides/argocd/" },
      { label: "FluxCD", href: "/docs/guides/fluxcd/" },
    ],
  },
  {
    label: "Infrastructure",
    items: [
      { label: "GCP", href: "/docs/guides/gcp/" },
      { label: "AWS", href: "/docs/guides/aws/" },
      { label: "Azure", href: "/docs/guides/azure/" },
    ],
  },
  {
    label: "Reference",
    items: [
      { label: "Components", href: "/docs/reference/components/" },
      { label: "Helm Charts Hub", href: "/docs/reference/hub/" },
      { label: "Policies", href: "/docs/reference/policies/" },
    ],
  },
];

const current = Astro.url.pathname.replace(/\/$/, "") || "/docs";
---

<Layout title={`${title} — Portefaix Docs`} description={description}>
  <div class="docs-shell">

    <!-- Sidebar toggle (mobile) -->
    <input type="checkbox" id="sidebar-toggle" class="sr-only" aria-hidden="true" />

    <!-- ── Sidebar ── -->
    <aside class="docs-sidebar glass" aria-label="Documentation navigation">
      <div class="sidebar-inner">

        <!-- Logo / back to home -->
        <a href="/" class="sidebar-logo" aria-label="Back to Portefaix home">
          <svg class="logo-hex" viewBox="0 0 24 24" fill="none" stroke="#00e5b0" stroke-width="1.5" aria-hidden="true">
            <polygon points="12,2 21,7 21,17 12,22 3,17 3,7"/>
            <circle cx="12" cy="12" r="2" fill="#00e5b0" stroke="none"/>
          </svg>
          <span class="logo-name">Portefaix</span>
          <span class="logo-tag">docs</span>
        </a>

        <hr class="nebl-divider" style="margin: 1rem 0 1.25rem;" />

        <!-- Nav tree -->
        {nav.map((group) => (
          <div class="nav-group">
            <p class="nav-group-label">{group.label}</p>
            <ul>
              {group.items.map((item) => {
                const active =
                  item.href === "/docs/"
                    ? current === "/docs"
                    : current.startsWith(item.href.replace(/\/$/, ""));
                return (
                  <li>
                    <a
                      href={item.href}
                      class={`nav-link ${active ? "nav-link--active" : ""}`}
                      aria-current={active ? "page" : undefined}
                    >
                      {item.label}
                    </a>
                  </li>
                );
              })}
            </ul>
          </div>
        ))}

        <!-- GitHub link -->
        <div class="sidebar-footer">
          <a
            href="https://github.com/portefaix"
            target="_blank"
            rel="noopener noreferrer"
            class="sidebar-gh"
          >
            <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" style="width:14px;height:14px;flex-shrink:0;">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
            GitHub
          </a>
        </div>

      </div>
    </aside>

    <!-- ── Mobile header ── -->
    <header class="docs-mobile-header glass">
      <label for="sidebar-toggle" class="mobile-menu-btn" aria-label="Toggle menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" style="width:18px;height:18px;">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
      </label>
      <a href="/" class="flex items-center gap-2.5" aria-label="Portefaix">
        <svg viewBox="0 0 24 24" fill="none" stroke="#00e5b0" stroke-width="1.5" style="width:18px;height:18px;" aria-hidden="true">
          <polygon points="12,2 21,7 21,17 12,22 3,17 3,7"/>
          <circle cx="12" cy="12" r="2" fill="#00e5b0" stroke="none"/>
        </svg>
        <span class="logo-name">Portefaix</span>
        <span class="logo-tag">docs</span>
      </a>
      <a href="https://github.com/portefaix" target="_blank" rel="noopener noreferrer" class="sidebar-gh">
        <svg viewBox="0 0 24 24" fill="currentColor" style="width:14px;height:14px;">
          <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
        </svg>
        GitHub
      </a>
    </header>

    <!-- ── Content ── -->
    <main class="docs-content">
      <!-- Star field behind content -->
      <canvas id="starfield" aria-hidden="true" style="position:fixed;inset:0;pointer-events:none;z-index:0;opacity:0.4;"></canvas>

      <article class="doc-article">
        <slot />
      </article>
    </main>

  </div>
</Layout>

<style>
/* ── Layout shell ──────────────────────────────── */
.docs-shell {
  display: grid;
  grid-template-columns: 260px 1fr;
  grid-template-rows: auto 1fr;
  min-height: 100vh;
}

/* ── Sidebar ───────────────────────────────────── */
.docs-sidebar {
  position: sticky;
  top: 0;
  height: 100vh;
  overflow-y: auto;
  grid-row: 1 / -1;
  border-right: 1px solid var(--glass-b);
  background: rgba(10, 11, 14, 0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  z-index: 40;
  scrollbar-width: thin;
  scrollbar-color: rgba(129, 140, 248, 0.2) transparent;
}

.sidebar-inner {
  padding: 1.5rem 1.25rem;
}

.sidebar-logo {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  margin-bottom: 0.25rem;
}

.logo-hex { width: 20px; height: 20px; flex-shrink: 0; }

.logo-name {
  font-family: var(--font-d);
  font-size: 1.05rem;
  font-weight: 300;
  letter-spacing: 0.06em;
  color: var(--t1);
}

.logo-tag {
  font-family: var(--font-m);
  font-size: 0.58rem;
  letter-spacing: 0.1em;
  color: #00e5b0;
  padding: 1px 7px;
  border: 1px solid rgba(129, 140, 248, 0.3);
  border-radius: 100px;
  margin-top: 2px;
}

.nav-group { margin-bottom: 1.5rem; }

.nav-group-label {
  font-family: var(--font-m);
  font-size: 0.58rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--t3);
  margin-bottom: 0.5rem;
  padding: 0 0.25rem;
}

.nav-group ul { list-style: none; display: flex; flex-direction: column; gap: 1px; }

.nav-link {
  display: block;
  font-family: var(--font-b);
  font-size: 0.85rem;
  font-weight: 400;
  color: var(--t2);
  text-decoration: none;
  padding: 0.38rem 0.6rem;
  border-radius: 6px;
  transition: background 0.2s, color 0.2s;
}

.nav-link:hover { background: rgba(255, 255, 255, 0.05); color: var(--t1); }

.nav-link--active {
  background: rgba(129, 140, 248, 0.12);
  color: #00e5b0;
  font-weight: 500;
}

.sidebar-footer {
  margin-top: 2rem;
  padding-top: 1rem;
  border-top: 1px solid var(--glass-b);
}

.sidebar-gh {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-family: var(--font-m);
  font-size: 0.65rem;
  letter-spacing: 0.08em;
  color: var(--t3);
  text-decoration: none;
  transition: color 0.2s;
}

.sidebar-gh:hover { color: var(--t1); }

/* ── Mobile header ────────────────────────────── */
.docs-mobile-header {
  display: none;
  align-items: center;
  justify-content: space-between;
  padding: 0 1rem;
  height: 52px;
  position: sticky;
  top: 0;
  z-index: 50;
  border-bottom: 1px solid var(--glass-b);
  background: rgba(10, 11, 14, 0.88);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  grid-column: 1 / -1;
}

.mobile-menu-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 8px;
  cursor: pointer;
  color: var(--t2);
  transition: background 0.2s, color 0.2s;
}

.mobile-menu-btn:hover { background: rgba(255, 255, 255, 0.07); color: var(--t1); }

.sr-only { position: absolute; width: 1px; height: 1px; padding: 0; margin: -1px; overflow: hidden; clip: rect(0,0,0,0); white-space: nowrap; border: 0; }

/* ── Content area ─────────────────────────────── */
.docs-content {
  position: relative;
  min-width: 0;
  grid-column: 2;
}

.doc-article {
  position: relative;
  z-index: 1;
  max-width: 760px;
  margin: 0 auto;
  padding: clamp(2.5rem, 6vw, 5rem) clamp(1.25rem, 4vw, 3rem);
}

/* ── Prose styles ─────────────────────────────── */
.doc-article :global(h1) {
  font-family: var(--font-d);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 300;
  letter-spacing: -0.02em;
  line-height: 1.1;
  color: var(--t1);
  margin-bottom: 1rem;
}

.doc-article :global(h2) {
  font-family: var(--font-d);
  font-size: clamp(1.35rem, 2.5vw, 1.75rem);
  font-weight: 300;
  letter-spacing: -0.01em;
  color: var(--t1);
  margin-top: 3rem;
  margin-bottom: 0.75rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--glass-b);
}

.doc-article :global(h3) {
  font-family: var(--font-b);
  font-size: 1.1rem;
  font-weight: 500;
  color: var(--t1);
  margin-top: 2rem;
  margin-bottom: 0.5rem;
}

.doc-article :global(p) {
  font-family: var(--font-b);
  font-size: 0.97rem;
  font-weight: 400;
  color: var(--t2);
  line-height: 1.8;
  margin-bottom: 1rem;
}

.doc-article :global(a) {
  color: #00e5b0;
  text-decoration: underline;
  text-underline-offset: 3px;
  transition: opacity 0.2s;
}

.doc-article :global(a:hover) { opacity: 0.75; }

.doc-article :global(ul), .doc-article :global(ol) {
  font-family: var(--font-b);
  font-size: 0.97rem;
  color: var(--t2);
  line-height: 1.8;
  padding-left: 1.5rem;
  margin-bottom: 1rem;
}

.doc-article :global(li) { margin-bottom: 0.3rem; }

.doc-article :global(code) {
  font-family: var(--font-m);
  font-size: 0.82rem;
  background: rgba(129, 140, 248, 0.1);
  border: 1px solid rgba(129, 140, 248, 0.18);
  border-radius: 4px;
  padding: 1px 6px;
  color: #67e8c8;
}

.doc-article :global(pre) {
  font-family: var(--font-m);
  font-size: 0.82rem;
  background: rgba(6, 0, 17, 0.7);
  border: 1px solid var(--glass-b);
  border-radius: 10px;
  padding: 1.25rem 1.5rem;
  overflow-x: auto;
  margin: 1.25rem 0;
  line-height: 1.7;
  color: var(--t2);
}

.doc-article :global(pre code) {
  background: none;
  border: none;
  padding: 0;
  color: inherit;
}

.doc-article :global(blockquote) {
  border-left: 2px solid rgba(129, 140, 248, 0.4);
  padding: 0.75rem 1.25rem;
  margin: 1.25rem 0;
  background: rgba(129, 140, 248, 0.05);
  border-radius: 0 8px 8px 0;
}

.doc-article :global(blockquote p) { margin-bottom: 0; }

.doc-article :global(table) {
  width: 100%;
  border-collapse: collapse;
  font-family: var(--font-b);
  font-size: 0.9rem;
  margin: 1.25rem 0;
}

.doc-article :global(th) {
  font-family: var(--font-m);
  font-size: 0.7rem;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: var(--t3);
  border-bottom: 1px solid var(--glass-b);
  padding: 0.6rem 0.75rem;
  text-align: left;
}

.doc-article :global(td) {
  color: var(--t2);
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  padding: 0.6rem 0.75rem;
  vertical-align: top;
}

.doc-article :global(hr) {
  border: none;
  height: 1px;
  background: linear-gradient(to right, transparent, var(--glass-b), transparent);
  margin: 2.5rem 0;
}

/* ── Doc breadcrumb / eyebrow ─────────────────── */
.doc-article :global(.doc-eyebrow) {
  font-family: var(--font-m);
  font-size: 0.62rem;
  letter-spacing: 0.14em;
  color: var(--t3);
  margin-bottom: 1rem;
  display: flex;
  align-items: center;
  gap: 0.5rem;
}

/* ── Callout box ──────────────────────────────── */
.doc-article :global(.callout) {
  border: 1px solid var(--glass-b);
  border-radius: 10px;
  padding: 1rem 1.25rem;
  margin: 1.25rem 0;
  background: var(--glass-bg);
}

.doc-article :global(.callout-info)  { border-color: rgba(0,229,176,0.3); background: rgba(0,229,176,0.05); }
.doc-article :global(.callout-warn)  { border-color: rgba(251,146,60,0.3);  background: rgba(251,146,60,0.05); }
.doc-article :global(.callout-tip)   { border-color: rgba(52,211,153,0.3);  background: rgba(52,211,153,0.05); }

/* ── Mobile layout ────────────────────────────── */
@media (max-width: 768px) {
  .docs-shell {
    grid-template-columns: 1fr;
    grid-template-rows: auto 1fr;
  }

  .docs-mobile-header { display: flex; }

  .docs-sidebar {
    position: fixed;
    top: 52px;
    left: 0;
    height: calc(100vh - 52px);
    width: 260px;
    transform: translateX(-100%);
    transition: transform 0.28s cubic-bezier(.16,1,.3,1);
    z-index: 45;
  }

  #sidebar-toggle:checked ~ .docs-sidebar { transform: translateX(0); }

  .docs-content { grid-column: 1; }
}
</style>

<script>
  // Star field (lighter opacity than homepage)
  const sf = document.getElementById("starfield") as HTMLCanvasElement | null;
  if (sf) {
    function paint() {
      sf!.width  = window.innerWidth;
      sf!.height = document.body.scrollHeight;
      const ctx = sf!.getContext("2d")!;
      const count = Math.floor((sf!.width * sf!.height) / 6000);
      for (let i = 0; i < count; i++) {
        const x = Math.random() * sf!.width;
        const y = Math.random() * sf!.height;
        const r = Math.random() * 0.9 + 0.2;
        const a = 0.1 + Math.random() * 0.5;
        ctx.beginPath();
        ctx.arc(x, y, r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(255,255,255,${a})`;
        ctx.fill();
      }
    }
    paint();
  }
</script>
